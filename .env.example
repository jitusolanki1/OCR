# Copy to .env and customise for your environment
# --------------------------------------------------

# API behaviour
DEBUG=false
APP_NAME="UPI OCR API"
APP_VERSION=1.0.0

# Server
HOST=0.0.0.0
PORT=8000

# OCR
OCR_LANG=en
OCR_USE_ANGLE_CLS=true
OCR_USE_GPU=false        # Set true on GPU hosts

# Uploads
MAX_UPLOAD_SIZE_MB=10

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json          # json | text
